{
  "name": "merlin",
  "private": true,
  "version": "3.3.12",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:cap": "cross-env CAPACITOR=true tsc && cross-env CAPACITOR=true vite build",
