    "postinstall": "node scripts/generate-icons.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor-community/text-to-speech": "^8.0.2",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capgo/capacitor-speech-recognition": "^8.1.3",
    "@sentry/browser": "10.52.0",
    "@sentry/capacitor": "4.1.0",
    "@upstash/redis": "^1.34.9",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "dompurify": "^3.4.11",
    "idb": "^8.0.3",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
